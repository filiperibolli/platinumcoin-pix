<?xml version="1.0" encoding="UTF-8"?>
<!--
  Shared logging configuration for EVERY PlatinumCoin service.

  This file is named `logback-spring.xml` and ships at the root of common-lib.jar, so
  Spring Boot's logback support auto-discovers it on the classpath of any service that
  depends on common-lib — no per-service logging file, no opt-in, no "I forgot the
  include and now this service silently logs plain text" failure mode. Add common-lib
  and you inherit structured JSON logging.

  It defines a JSON appender (logstash-logback-encoder) whose lines carry timestamp, level,
  logger, message and every MDC entry — crucially correlationId and txId — so one id
  reconstructs a request's full path via `jq 'select(.correlationId=="…")'`.

  The `dev` Spring profile swaps in a human-readable console pattern; anything else logs JSON.

  Per-service tuning: adjust levels via `logging.level.*` in the service's application.yml
  (Spring applies them over this config) — that covers the common case without a competing
  logback file. A service must NOT ship its own logback-spring.xml: two of them on the
  classpath resolve non-deterministically. Structural log shape is deliberately uniform
  across services (that uniformity is what makes correlationId tracing work), so it is owned
  here, not overridable per service.

  Named logback-spring.xml (not logback.xml) because <springProfile> below is a Spring Boot
  logback extension — plain logback would not resolve those tags.
-->
<configuration>

    <!-- Structured JSON for real environments (and for local greppability). -->
    <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <logger>logger</logger>
                <thread>[ignore]</thread>
                <version>[ignore]</version>
                <levelValue>[ignore]</levelValue>
            </fieldNames>
            <!-- correlationId and txId flow in automatically as MDC entries. -->
        </encoder>
    </appender>

    <!-- Human-readable console for local `dev` work. -->
    <appender name="PLAIN" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%X{correlationId}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="PLAIN"/>
        </root>
    </springProfile>

    <springProfile name="!dev">
        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>
    </springProfile>

</configuration>
